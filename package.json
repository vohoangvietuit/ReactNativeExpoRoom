{
  "name": "fitsync-monorepo",
  "version": "0.0.1",
  "private": true,
  "description": "FitSync — Offline-first event-driven body management app",
  "scripts": {
    "dev": "pnpm --filter @fitsync/mobile expo start",
    "android": "pnpm --filter @fitsync/mobile expo run:android",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean",
    "storybook": "pnpm --filter @fitsync/ui storybook",
    "storybook:mobile": "pnpm --filter @fitsync/mobile storybook:android",
    "storybook:generate": "pnpm --filter @fitsync/mobile storybook:generate"
  },
  "devDependencies": {
    "turbo": "^2.5.0",
    "prettier": "^3.5.0",
    "typescript": "~5.8.3"
  },
  "resolutions": {
    "react": "19.2.0",
    "react-native": "0.83.4"
  },
  "packageManager": "pnpm@10.20.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
